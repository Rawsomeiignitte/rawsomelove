<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Rawsome Love Library</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Dancing+Script:wght@500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #f5f7fa;
    --card-bg: #ffffff;
    --text: #1a1a1a;
    --text-muted: #6b7280;
    --border: #e5e7eb;
    --border-soft: #eef0f3;
    --accent: #c97a2b;          /* orange brand */
    --accent-dark: #5a2e0f;     /* deep brown */
    --accent-light: #fdf1e3;    /* highlight wash */
    --green: #1cb978;
    --green-hover: #16a368;
    --tab-active-bg: #e7f0fb;
    --tab-active-text: #1f6feb;
    --shadow-sm: 0 1px 2px rgba(15,23,42,.04), 0 1px 3px rgba(15,23,42,.06);
    --shadow-md: 0 4px 12px rgba(15,23,42,.06), 0 2px 4px rgba(15,23,42,.04);
  }

  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background: var(--bg);
    color: var(--text);
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
  }

  button { font-family: inherit; cursor: pointer; border: none; background: none; }
  a { color: inherit; text-decoration: none; }

  /* ---------- Top Nav ---------- */
  .topnav {
    background: #fff;
    border-bottom: 1px solid var(--border-soft);
    padding: 14px 32px;
    display: flex;
    align-items: center;
    gap: 16px;
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .topnav .left { display: flex; align-items: center; gap: 16px; flex: 0 0 auto; }
  .topnav .home-btn,
  .topnav .icon-btn {
    width: 38px; height: 38px;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 8px;
    color: #2a2a2a;
    transition: background .15s ease;
  }
  .topnav .home-btn:hover,
  .topnav .icon-btn:hover { background: #f0f2f5; }

  .brand-script {
    font-family: 'Dancing Script', cursive;
    font-size: 20px;
    font-weight: 600;
    color: #2a2a2a;
    line-height: 1;
  }

  .search {
    flex: 1;
    max-width: 720px;
    margin: 0 auto;
    position: relative;
  }
  .search input {
    width: 100%;
    height: 44px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: #fff;
    padding: 0 18px 0 46px;
    font-size: 14px;
    color: var(--text);
    outline: none;
    transition: border-color .15s ease, box-shadow .15s ease;
  }
  .search input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(201,122,43,.12);
  }
  .search input::placeholder { color: #9aa3ad; }
  .search svg {
    position: absolute;
    left: 16px; top: 50%;
    transform: translateY(-50%);
    color: #6b7280;
  }

  .topnav .right {
    display: flex; align-items: center; gap: 8px;
    flex: 0 0 auto;
  }
  .avatar-initial {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: #fff;
    color: #2a2a2a;
    font-weight: 700;
    font-size: 13px;
    display: inline-flex; align-items: center; justify-content: center;
  }

  /* ---------- Page wrapper / views ---------- */
  .view { display: none; }
  .view.active { display: block; }

  /* ---------- LIBRARY VIEW ---------- */
  .library {
    max-width: 1280px;
    margin: 0 auto;
    padding: 36px 48px 80px;
  }

  .tabs {
    display: flex;
    align-items: center;
    gap: 28px;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0;
    margin-bottom: 36px;
  }
  .tab {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 4px 14px;
    font-size: 15px;
    font-weight: 500;
    color: #4a5260;
    position: relative;
    transition: color .15s ease;
  }
  .tab .count {
    display: inline-flex;
    min-width: 22px; height: 22px;
    padding: 0 8px;
    border-radius: 6px;
    background: #eef2f7;
    color: #4a5260;
    font-size: 12px;
    font-weight: 600;
    align-items: center; justify-content: center;
  }
  .tab.active { color: var(--tab-active-text); }
  .tab.active .count { background: var(--tab-active-bg); color: var(--tab-active-text); }
  .tab.active::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: -1px;
    height: 2px;
    background: var(--tab-active-text);
    border-radius: 2px;
  }
  .tab:hover { color: #1a1a1a; }
  .tab.active:hover { color: var(--tab-active-text); }

  .courses-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 360px));
    gap: 24px;
  }

  .course-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
    cursor: pointer;
    display: flex;
    flex-direction: column;
  }
  .course-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: #d6dae0;
  }

  .course-thumb {
    aspect-ratio: 16 / 9;
    margin: 14px 14px 0;
    border-radius: 8px;
    background:
      radial-gradient(120% 100% at 100% 0%, #d68845 0%, #b76a2c 38%, #6b3414 78%, #3a1c08 100%);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    padding: 18px 22px;
  }
  .course-thumb .badges {
    position: absolute;
    bottom: 14px; left: 18px;
    display: flex; gap: 6px;
  }
  .course-thumb .badge {
    width: 26px; height: 26px;
    border-radius: 50%;
    background: #fff;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 8px; font-weight: 800;
    color: #2a2a2a;
    box-shadow: 0 1px 2px rgba(0,0,0,.2);
    border: 1.5px solid rgba(255,255,255,.9);
  }
  .course-thumb .badge.b1 { background: #fff; color: #1a3a8a; }
  .course-thumb .badge.b2 { background: #fff; color: #b76a2c; }
  .course-thumb .badge.b3 { background: #1a1a1a; color: #d4a050; }
  .course-thumb .signature {
    position: absolute;
    bottom: 18px; right: 22px;
    font-family: 'Dancing Script', cursive;
    font-size: 18px;
    font-weight: 500;
    color: #fff;
    opacity: .92;
  }
  .course-thumb .title-block { color: #fff; }
  .course-thumb .title-block .eyebrow {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: .04em;
    color: #f4a85a;
    margin-bottom: 4px;
  }
  .course-thumb .title-block .title {
    font-size: 22px;
    font-weight: 800;
    letter-spacing: .02em;
    line-height: 1.1;
  }

  .course-body {
    padding: 18px 22px 14px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .course-body h3 {
    margin: 0 0 24px;
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
  }
  .progress-row {
    display: flex; align-items: center; gap: 12px;
    margin-top: auto;
    padding-bottom: 12px;
  }
  .progress-bar {
    flex: 1;
    height: 6px;
    background: #ececec;
    border-radius: 999px;
    overflow: hidden;
  }
  .progress-bar > span {
    display: block;
    height: 100%;
    background: var(--accent);
    border-radius: 999px;
    transition: width .3s ease;
  }
  .progress-pct {
    font-size: 13px;
    font-weight: 600;
    color: #4a5260;
  }

  .course-footer {
    border-top: 1px solid var(--border-soft);
    padding: 14px 22px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .coach-avatar {
    width: 38px; height: 38px;
    border-radius: 8px;
    background: #5a2e0f;
    overflow: hidden;
    display: inline-flex; align-items: center; justify-content: center;
    color: #fff; font-weight: 700; font-size: 14px;
  }
  .coach-name {
    font-size: 14px;
    font-weight: 700;
    color: var(--text);
    flex: 1;
  }
  .pill {
    background: var(--green);
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    padding: 8px 18px;
    border-radius: 999px;
    transition: background .15s ease;
  }
  .pill:hover { background: var(--green-hover); }

  /* ---------- COURSE DETAIL VIEW ---------- */
  .course-hero {
    position: relative;
    background:
      radial-gradient(120% 120% at 100% 50%, #d68845 0%, #b76a2c 30%, #6b3414 70%, #2c1306 100%);
    color: #fff;
    overflow: hidden;
    min-height: 360px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px 32px;
  }
  .course-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(60% 60% at 20% 90%, rgba(255,255,255,.04), transparent 60%),
      radial-gradient(40% 40% at 80% 10%, rgba(255,200,140,.10), transparent 60%);
    pointer-events: none;
  }
  .hero-logo {
    position: absolute;
    left: 32px; top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 6px;
    z-index: 2;
  }
  .hero-logo .name {
    font-family: 'Dancing Script', cursive;
    font-size: 44px;
    font-weight: 600;
    line-height: 1;
    color: #fff;
    text-shadow: 0 2px 8px rgba(0,0,0,.15);
  }
  .hero-logo .tags {
    display: flex; gap: 6px;
    margin-top: 4px;
  }
  .hero-logo .tag {
    background: #f5c842;
    color: #1a1a1a;
    font-size: 11px;
    font-weight: 800;
    padding: 4px 10px;
    border-radius: 4px;
    letter-spacing: .05em;
  }
  .hero-logo .tag.dark { background: #1a1a1a; color: #f5c842; }

  .hero-content {
    text-align: center;
    z-index: 1;
  }
  .hero-content h1 {
    margin: 0 0 28px;
    font-size: 42px;
    font-weight: 800;
    letter-spacing: .04em;
    text-shadow: 0 2px 12px rgba(0,0,0,.15);
  }
  .start-btn {
    background: #4a230b;
    color: #fff;
    font-size: 16px;
    font-weight: 700;
    padding: 16px 44px;
    border-radius: 6px;
    transition: background .15s ease, transform .15s ease;
    box-shadow: 0 4px 14px rgba(0,0,0,.18);
  }
  .start-btn:hover { background: #5a2e0f; transform: translateY(-1px); }

  .course-detail {
    max-width: 1280px;
    margin: 0 auto;
    padding: 32px 32px 80px;
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 32px;
    align-items: start;
  }
  @media (max-width: 980px) {
    .course-detail { grid-template-columns: 1fr; }
    .hero-logo { display: none; }
    .hero-content h1 { font-size: 30px; }
  }

  /* Accordion */
  .accordion {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }
  .accordion-header {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 28px;
    font-size: 17px;
    font-weight: 700;
    color: var(--text);
    text-align: left;
    transition: background .15s ease;
  }
  .accordion-header:hover { background: #fafbfc; }
  .accordion-header .chev {
    transition: transform .25s ease;
    color: #6b7280;
  }
  .accordion.open .accordion-header .chev { transform: rotate(90deg); }
  .accordion.open-down .accordion-header .chev { transform: rotate(90deg); }

  .accordion-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height .35s ease;
    border-top: 0 solid var(--border-soft);
  }
  .accordion.open .accordion-body {
    max-height: 12000px;
    border-top: 1px solid var(--border-soft);
  }

  .lesson {
    display: flex;
    align-items: center;
    gap: 22px;
    padding: 18px 28px;
    border-bottom: 1px solid var(--border-soft);
    transition: background .15s ease;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
  }
  .lesson:last-child { border-bottom: none; }
  .lesson:hover { background: #fafbfc; }
  .lesson.current { background: var(--accent-light); }
  .lesson.current:hover { background: #fbe8d2; }
  .lesson-arrow {
    color: #c0c5cd;
    flex-shrink: 0;
    transition: color .15s ease, transform .15s ease;
  }
  .lesson:hover .lesson-arrow {
    color: var(--accent);
    transform: translateX(2px);
  }

  .lesson-thumb {
    flex: 0 0 auto;
    width: 168px;
    aspect-ratio: 16 / 9;
    border-radius: 8px;
    background:
      radial-gradient(120% 100% at 100% 0%, #e89a55 0%, #c8782e 40%, #6b3414 85%, #3a1c08 100%);
    position: relative;
    overflow: hidden;
    padding: 14px 16px;
    color: #fff;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .lesson-thumb .lt-eyebrow {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: .03em;
    line-height: 1;
  }
  .lesson-thumb .lt-title {
    font-size: 15px;
    font-weight: 800;
    letter-spacing: .02em;
    line-height: 1;
    margin-top: 2px;
  }
  .lesson-thumb .lt-tag {
    font-size: 8px;
    font-weight: 500;
    color: rgba(255,255,255,.85);
    letter-spacing: .02em;
  }
  .lesson-thumb .lt-tag b { font-weight: 700; }
  .lesson-thumb .lt-bottom {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
  }
  .lesson-thumb .lt-badges { display: flex; gap: 3px; }
  .lesson-thumb .lt-badges .lb {
    width: 10px; height: 10px;
    border-radius: 50%;
    background: #fff;
    border: 1px solid rgba(255,255,255,.6);
  }
  .lesson-thumb .lt-badges .lb:nth-child(2) { background: #2a1306; }
  .lesson-thumb .lt-badges .lb:nth-child(3) { background: #1a1a1a; }
  .lesson-thumb .lt-sig {
    font-family: 'Dancing Script', cursive;
    font-size: 12px;
    color: rgba(255,255,255,.9);
  }

  .lesson-text {
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
    line-height: 1.45;
    flex: 1;
  }

  /* Sidebar */
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: 20px;
    position: sticky;
    top: 88px;
  }
  .side-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    padding: 18px;
  }
  .side-thumb {
    aspect-ratio: 16 / 9;
    border-radius: 8px;
    background: radial-gradient(120% 100% at 100% 0%, #d68845 0%, #b76a2c 38%, #6b3414 78%, #3a1c08 100%);
    position: relative;
    overflow: hidden;
    padding: 22px 24px;
    color: #fff;
    margin-bottom: 18px;
  }
  .side-thumb .eyebrow {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: .04em;
    color: #f4a85a;
    margin-bottom: 4px;
  }
  .side-thumb .title {
    font-size: 22px;
    font-weight: 800;
    letter-spacing: .02em;
    line-height: 1.1;
  }
  .side-thumb .badges {
    position: absolute;
    bottom: 16px; left: 24px;
    display: flex; gap: 5px;
  }
  .side-thumb .badge {
    width: 22px; height: 22px;
    border-radius: 50%;
    background: #fff;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 7px; font-weight: 800;
    border: 1px solid rgba(255,255,255,.9);
  }
  .side-thumb .badge.b1 { background: #fff; color: #1a3a8a; }
  .side-thumb .badge.b2 { background: #fff; color: #b76a2c; }
  .side-thumb .badge.b3 { background: #1a1a1a; color: #d4a050; }
  .side-thumb .signature {
    position: absolute;
    bottom: 18px; right: 22px;
    font-family: 'Dancing Script', cursive;
    font-size: 16px;
    color: #fff;
  }
  .lessons-completed {
    font-size: 15px;
    font-weight: 700;
    color: var(--accent);
    margin: 0 0 12px;
  }

  .coach-card {
    padding: 22px;
  }
  .coach-card h4 {
    margin: 0 0 14px;
    font-size: 18px;
    font-weight: 800;
    color: var(--text);
  }
  .coach-row {
    display: flex; align-items: center; gap: 14px;
  }
  .coach-row .ca {
    width: 48px; height: 48px;
    border-radius: 8px;
    background: #5a2e0f;
    overflow: hidden;
    flex-shrink: 0;
  }
  .coach-row .ci .name {
    color: var(--accent);
    font-size: 15px;
    font-weight: 700;
    margin-bottom: 2px;
  }
  .coach-row .ci .role {
    color: #4a5260;
    font-size: 14px;
    font-weight: 500;
  }

  /* Avatar (Kenny Lee) - simple stylized */
  .ca svg { width: 100%; height: 100%; display: block; }

  /* ---------- Password Gate ---------- */
  .gate {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background:
      radial-gradient(120% 100% at 100% 0%, #d68845 0%, #b76a2c 38%, #6b3414 78%, #2c1306 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }
  .gate-card {
    background: #fff;
    border-radius: 16px;
    padding: 44px 40px 36px;
    max-width: 420px;
    width: 100%;
    box-shadow: 0 20px 60px rgba(0,0,0,.25);
    text-align: center;
  }
  .gate-brand {
    font-family: 'Dancing Script', cursive;
    font-size: 32px;
    color: var(--accent-dark);
    margin-bottom: 4px;
    line-height: 1;
  }
  .gate-card h2 {
    margin: 0 0 8px;
    font-size: 22px;
    font-weight: 800;
    color: var(--text);
    letter-spacing: .02em;
  }
  .gate-card p {
    margin: 0 0 28px;
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.5;
  }
  .gate-input-wrap {
    position: relative;
    margin-bottom: 14px;
  }
  .gate-input {
    width: 100%;
    height: 48px;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    padding: 0 46px 0 16px;
    font-size: 15px;
    font-family: inherit;
    color: var(--text);
    outline: none;
    transition: border-color .15s ease, box-shadow .15s ease;
  }
  .gate-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(201,122,43,.12);
  }
  .gate-toggle {
    position: absolute;
    right: 12px; top: 50%;
    transform: translateY(-50%);
    width: 32px; height: 32px;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 6px;
    color: #6b7280;
    background: none;
    border: none;
    cursor: pointer;
  }
  .gate-toggle:hover { background: #f0f2f5; color: #1a1a1a; }
  .gate-btn {
    width: 100%;
    height: 48px;
    background: var(--accent-dark);
    color: #fff;
    font-size: 15px;
    font-weight: 700;
    border-radius: 10px;
    transition: background .15s ease, transform .1s ease;
    letter-spacing: .02em;
  }
  .gate-btn:hover { background: #4a230b; }
  .gate-btn:active { transform: translateY(1px); }
  .gate-error {
    color: #c92a2a;
    font-size: 13px;
    font-weight: 500;
    margin-top: 10px;
    min-height: 18px;
  }
  body.locked { overflow: hidden; }
  body.locked .topnav,
  body.locked .view { visibility: hidden; }

  /* ---------- Mobile responsive ---------- */
  @media (max-width: 768px) {
    .topnav {
      padding: 10px 14px;
      gap: 10px;
    }
    .topnav .home-btn,
    .topnav .icon-btn {
      width: 36px; height: 36px;
    }
    .brand-script { font-size: 16px; }
    .search input {
      height: 40px;
      font-size: 13px;
      padding: 0 14px 0 40px;
    }
    .search svg { left: 12px; width: 16px; height: 16px; }

    .library {
      padding: 22px 16px 60px;
    }
    .tabs {
      gap: 18px;
      margin-bottom: 24px;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    .tab {
      font-size: 14px;
      flex-shrink: 0;
    }
    .courses-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .course-hero {
      min-height: auto;
      padding: 56px 20px 48px;
    }
    .hero-content h1 {
      font-size: 24px;
      margin-bottom: 22px;
      line-height: 1.2;
    }
    .start-btn {
      font-size: 14px;
      padding: 13px 32px;
    }
    .back-link {
      top: 14px; left: 14px;
      font-size: 12px;
      padding: 6px 12px;
    }

    .course-detail {
      padding: 20px 14px 60px;
      gap: 20px;
    }

